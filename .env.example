DATABASE_URL="file:./dev.db"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# TTL кэша ответов LLM на сервере (мс), по умолчанию 300000; 0 — не кэшировать
LLM_CACHE_TTL_MS=300000
# Лимит LLM-запросов с одного клиента (IP / x-forwarded-for) за окно; 0 — отключить
LLM_RATE_LIMIT_MAX=30
LLM_RATE_LIMIT_WINDOW_MS=60000
# 1 — писать в stdout сведения о токенах (usage) после ответов OpenAI
LLM_LOG_USAGE=
